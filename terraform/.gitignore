# Downloaded provider plugins — regenerated by terraform init
.terraform/

# Crash logs
crash.log
crash.*.log

# Your actual secrets and IP — never commit this
terraform.tfvars
*.auto.tfvars

# Local override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json
*.zip